{
  "manifest_version": 3,
  "name": "Waffy",
  "version": "1.0.0",
  "description": "Waffy is a chrome extension designed to enhance your browsing experience.",
  "icons": {
    "64": "icons/logo64.png",
    "128": "icons/logo128.png",
    "256": "icons/logo256.png"
  },
  "background": {
    "service_worker": "./static/js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "./static/js/content.js"
      ]
    }
  ],
  "options_page": "settings.html",
  "commands": {
    "open_sidepanel": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      },
      "description": "Open side panel"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "permissions": [
    "storage",
    "tabs",
    "sidePanel",
    "activeTab",
    "tabs",
    "debugger"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "<all_urls>"
  ],
  "author": "Waffy"
}