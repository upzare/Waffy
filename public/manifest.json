{
  "manifest_version": 3,
  "name": "Waffy",
  "version": "1.0.0",
  "description": "Waffy is a chrome extension designed to enhance your browsing experience.",
  "icons": {
    "64": "assets/icons/logo64.png",
    "128": "assets/icons/logo128.png",
    "256": "assets/icons/logo256.png"
  },
  "action": {
    "default_title": "Open Waffy"
  },
  "background": {
    "service_worker": "background.bundle.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.bundle.js"
      ]
    }
  ],
  "options_page": "settings.html",
  "commands": {
    "open_side_panel": {
      "suggested_key": {
        "default": "Ctrl+I"
      },
      "description": "Open Waffy Side Panel"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "permissions": [
    "storage",
    "tabs",
    "sidePanel",
    "activeTab",
    "tabs",
    "debugger",
    "webNavigation",
    "cookies"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "shared/cursor.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "author": "Waffy Inc"
}